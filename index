 (cd "$(git rev-parse --show-toplevel)" && git apply --3way <<'EOF' 
diff --git a/index.html b/index.html
new file mode 100644
index 0000000000000000000000000000000000000000..cde4c1fd32824ea903a1b2ee0cd7fc25f3838a32
--- /dev/null
+++ b/index.html
@@ -0,0 +1,233 @@
+<!DOCTYPE html>
+<html lang="ko">
+<head>
+  <meta charset="UTF-8" />
+  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
+  <title>사업 감각 테스트</title>
+  <style>
+    :root {
+      --bg: #f6f8fb;
+      --card: #ffffff;
+      --text: #1f2a37;
+      --sub: #6b7280;
+      --accent: #0064ff;
+      --accent-soft: #e8f0ff;
+      --border: #e5e7eb;
+      --good: #0ea5a4;
+    }
+
+    * { box-sizing: border-box; }
+
+    body {
+      margin: 0;
+      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Noto Sans KR", sans-serif;
+      background: linear-gradient(180deg, #f3f7ff 0%, var(--bg) 100%);
+      color: var(--text);
+      min-height: 100vh;
+      display: flex;
+      align-items: center;
+      justify-content: center;
+      padding: 24px;
+    }
+
+    .app {
+      width: min(700px, 100%);
+      background: var(--card);
+      border: 1px solid var(--border);
+      border-radius: 18px;
+      box-shadow: 0 10px 35px rgba(17, 24, 39, 0.08);
+      overflow: hidden;
+    }
+
+    .header {
+      padding: 28px;
+      border-bottom: 1px solid var(--border);
+      background: #fff;
+    }
+
+    .title {
+      margin: 0;
+      font-size: 1.5rem;
+      font-weight: 700;
+    }
+
+    .desc {
+      margin: 10px 0 0;
+      color: var(--sub);
+      line-height: 1.5;
+    }
+
+    .content {
+      padding: 28px;
+    }
+
+    .progress {
+      color: var(--sub);
+      font-size: 0.95rem;
+      margin-bottom: 14px;
+    }
+
+    .question {
+      margin: 0 0 22px;
+      font-size: 1.3rem;
+      line-height: 1.5;
+      min-height: 84px;
+    }
+
+    .choices {
+      display: grid;
+      grid-template-columns: 1fr 1fr;
+      gap: 12px;
+    }
+
+    button {
+      border: 1px solid var(--border);
+      border-radius: 12px;
+      background: #fff;
+      color: var(--text);
+      font-size: 1.1rem;
+      font-weight: 700;
+      padding: 16px;
+      cursor: pointer;
+      transition: all 0.15s ease;
+    }
+
+    button:hover {
+      border-color: var(--accent);
+      background: var(--accent-soft);
+    }
+
+    .result {
+      background: #fff;
+      border: 1px solid var(--border);
+      border-radius: 16px;
+      padding: 22px;
+      margin-top: 8px;
+    }
+
+    .score {
+      margin: 0;
+      font-size: 1.2rem;
+      font-weight: 700;
+      color: var(--good);
+    }
+
+    .comment {
+      margin: 12px 0 0;
+      color: var(--sub);
+      line-height: 1.6;
+    }
+
+    .restart {
+      margin-top: 20px;
+      width: 100%;
+      border-color: var(--accent);
+      color: var(--accent);
+    }
+
+    @media (max-width: 560px) {
+      .choices { grid-template-columns: 1fr; }
+      .question { min-height: auto; }
+      .content, .header { padding: 20px; }
+    }
+  </style>
+</head>
+<body>
+  <main class="app">
+    <header class="header">
+      <h1 class="title">나의 사업 감각 확인 테스트</h1>
+      <p class="desc">10가지 질문에 O/X로 답해보세요. 실전 감각에 얼마나 가까운지 빠르게 확인할 수 있어요.</p>
+    </header>
+
+    <section class="content" id="quizSection">
+      <p class="progress" id="progress"></p>
+      <h2 class="question" id="question"></h2>
+      <div class="choices">
+        <button id="yesBtn" type="button" aria-label="O 선택">O</button>
+        <button id="noBtn" type="button" aria-label="X 선택">X</button>
+      </div>
+    </section>
+
+    <section class="content" id="resultSection" hidden>
+      <div class="result">
+        <p class="score" id="score"></p>
+        <p class="comment" id="comment"></p>
+        <button class="restart" id="restartBtn" type="button">다시 테스트하기</button>
+      </div>
+    </section>
+  </main>
+
+  <script>
+    const questions = [
+      { text: "새로운 아이디어를 떠올리면 먼저 고객이 겪는 문제를 적어본다.", answer: true },
+      { text: "제품/서비스 가격을 정할 때 원가보다 고객 가치 기준을 더 우선한다.", answer: true },
+      { text: "경쟁 서비스를 써보고 장단점을 정리해본 적이 있다.", answer: true },
+      { text: "매출이 없어도 일단 광고를 크게 집행하는 편이 낫다고 생각한다.", answer: false },
+      { text: "가설을 세우고 작게 실험해본 뒤 결과로 의사결정을 한다.", answer: true },
+      { text: "한 번 정한 계획은 시장 반응이 달라도 그대로 밀어붙이는 편이다.", answer: false },
+      { text: "고객 인터뷰나 후기에서 반복되는 불만을 기회로 본다.", answer: true },
+      { text: "수익 구조(어디서 돈을 버는지)를 먼저 설계하는 편이다.", answer: true },
+      { text: "팀원이 반대하면 데이터 없이도 감으로만 결정하는 편이다.", answer: false },
+      { text: "실패한 시도도 기록해서 다음 실험의 재료로 활용한다.", answer: true }
+    ];
+
+    let current = 0;
+    let score = 0;
+
+    const progressEl = document.getElementById('progress');
+    const questionEl = document.getElementById('question');
+    const quizSection = document.getElementById('quizSection');
+    const resultSection = document.getElementById('resultSection');
+    const scoreEl = document.getElementById('score');
+    const commentEl = document.getElementById('comment');
+
+    function renderQuestion() {
+      const total = questions.length;
+      progressEl.textContent = `${current + 1} / ${total} 질문`;
+      questionEl.textContent = questions[current].text;
+    }
+
+    function getComment(finalScore) {
+      if (finalScore >= 9) return '훌륭해요! 이미 사업가 마인드가 잘 잡혀 있어요. 작은 실행을 빠르게 반복해보세요.';
+      if (finalScore >= 7) return '좋아요! 기본 감각이 탄탄합니다. 고객 검증 루틴을 더 강화하면 더 빠르게 성장할 수 있어요.';
+      if (finalScore >= 5) return '가능성이 충분해요. 데이터를 기반으로 판단하는 습관을 늘리면 사업 감각이 더 선명해집니다.';
+      return '아직은 감보다 근거가 필요해요. 고객 문제 정의와 작은 실험부터 시작해보세요.';
+    }
+
+    function selectAnswer(choice) {
+      if (choice === questions[current].answer) {
+        score += 1;
+      }
+
+      current += 1;
+
+      if (current >= questions.length) {
+        showResult();
+      } else {
+        renderQuestion();
+      }
+    }
+
+    function showResult() {
+      quizSection.hidden = true;
+      resultSection.hidden = false;
+      scoreEl.textContent = `결과: 10문항 중 ${score}개 정답`;
+      commentEl.textContent = getComment(score);
+    }
+
+    function restartQuiz() {
+      current = 0;
+      score = 0;
+      resultSection.hidden = true;
+      quizSection.hidden = false;
+      renderQuestion();
+    }
+
+    document.getElementById('yesBtn').addEventListener('click', () => selectAnswer(true));
+    document.getElementById('noBtn').addEventListener('click', () => selectAnswer(false));
+    document.getElementById('restartBtn').addEventListener('click', restartQuiz);
+
+    renderQuestion();
+  </script>
+</body>
+</html>
 
EOF
)
